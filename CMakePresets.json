{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "QASR_ENABLE_TESTS": "ON"
      }
    },
    {
      "name": "macos-accelerate",
      "inherits": "base",
      "description": "macOS / Apple Accelerate"
    },
    {
      "name": "macos-accelerate-asan",
      "inherits": "macos-accelerate",
      "description": "macOS / Apple Accelerate with ASan/UBSan",
      "cacheVariables": {
        "QASR_ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "linux-openblas",
      "inherits": "base",
      "description": "Linux / OpenBLAS"
    },
    {
      "name": "linux-openblas-asan",
      "inherits": "linux-openblas",
      "description": "Linux / OpenBLAS with ASan/UBSan",
      "cacheVariables": {
        "QASR_ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "windows-openblas",
      "inherits": "base",
      "description": "Windows / OpenBLAS"
    }
  ],
  "buildPresets": [
    {
      "name": "macos-accelerate",
      "configurePreset": "macos-accelerate"
    },
    {
      "name": "macos-accelerate-asan",
      "configurePreset": "macos-accelerate-asan"
    },
    {
      "name": "linux-openblas",
      "configurePreset": "linux-openblas"
    },
    {
      "name": "linux-openblas-asan",
      "configurePreset": "linux-openblas-asan"
    },
    {
      "name": "windows-openblas",
      "configurePreset": "windows-openblas"
    }
  ],
  "testPresets": [
    {
      "name": "macos-accelerate",
      "configurePreset": "macos-accelerate",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-accelerate-asan",
      "configurePreset": "macos-accelerate-asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-openblas",
      "configurePreset": "linux-openblas",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-openblas-asan",
      "configurePreset": "linux-openblas-asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-openblas",
      "configurePreset": "windows-openblas",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
